# ─── CLERK AUTHENTICATION ───
# [CLIENT] Found in Clerk Dashboard -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# [SERVER] Found in Clerk Dashboard -> API Keys
CLERK_SECRET_KEY=sk_live_...

# [SERVER] Found in Clerk Dashboard -> Webhooks (Endpoint Secret)
CLERK_WEBHOOK_SECRET=whsec_...

# [CLIENT] Clerk Routing URLs (Standard values)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard


# ─── SUPABASE DATABASE ───
# [CLIENT] Found in Supabase Dashboard -> Project Settings -> API (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://...supabase.co

# [CLIENT] Found in Supabase Dashboard -> Project Settings -> API (Project API Keys -> anon, public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# [SERVER] Found in Supabase Dashboard -> Project Settings -> API (Project API Keys -> service_role)
# DANGER: Never expose this to the browser!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...


# ─── PAYMENTS (PADDLE) ───
# [SERVER] Found in Paddle Dashboard -> Developer Tools -> Authentication (API Keys)
PADDLE_API_KEY=pdl_live_apikey_...

# [SERVER] Found in Paddle Dashboard -> Developer Tools -> Webhooks (Secret Key)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# [CLIENT] Found in Paddle Dashboard -> Developer Tools -> Authentication (Client-side tokens)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_...

# [SERVER] Set to "production" or "sandbox"
PADDLE_ENV=production
NEXT_PUBLIC_PADDLE_ENV=production

# [CLIENT] Paddle Product Price IDs (Found in Paddle Dashboard -> Catalog -> Products -> Prices)
NEXT_PUBLIC_PADDLE_PRICE_STARTER_MONTHLY=pri_...
NEXT_PUBLIC_PADDLE_PRICE_STARTER_YEARLY=pri_...
NEXT_PUBLIC_PADDLE_PRICE_BASIC_MONTHLY=pri_...
NEXT_PUBLIC_PADDLE_PRICE_BASIC_YEARLY=pri_...
NEXT_PUBLIC_PADDLE_PRICE_GROWTH_MONTHLY=pri_...
NEXT_PUBLIC_PADDLE_PRICE_GROWTH_YEARLY=pri_...
NEXT_PUBLIC_PADDLE_PRICE_PRO_MONTHLY=pri_...
NEXT_PUBLIC_PADDLE_PRICE_PRO_YEARLY=pri_...

# Addon Credit Packs
NEXT_PUBLIC_PADDLE_PRICE_ADDON_200=pri_...
NEXT_PUBLIC_PADDLE_PRICE_ADDON_600=pri_...
NEXT_PUBLIC_PADDLE_PRICE_ADDON_1000=pri_...


# ─── AI PROVIDER (GEMINI) ───
# [SERVER] Set manually
AI_PROVIDER=gemini

# [SERVER] Found in Google AI Studio -> API Keys
GEMINI_API_KEY=AIzaSy...


# ─── APP CONFIGURATION ───
# [CLIENT] The primary canonical URL for the app
NEXT_PUBLIC_APP_URL=https://auricai.tech

# [CLIENT] Used for specific production-only checks
NEXT_PUBLIC_PRODUCTION_URL=https://auricai.tech

# [CLIENT] The naked domain
NEXT_PUBLIC_DOMAIN=auricai.tech
